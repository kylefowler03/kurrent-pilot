_for_bucket_v1(b);\n  exception when undefined_function or undefined_table then\n    null;\n  end;\n  t1 := clock_timestamp();\n  raise notice 'compute_field_memory_for_bucket_v1 (or skipped): % ms', extract(epoch from (t1 - t0)) * 1000;\nend;\n$function$\n"
